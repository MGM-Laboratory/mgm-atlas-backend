// MGM Atlas — primary data model
// Postgres lives on an external host; we never embed it in docker-compose.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum ProjectPhase {
  IDEA
  PLANNING
  IN_DEVELOPMENT
  IN_REVIEW
  SHIPPED
  ARCHIVED
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

enum ProjectRole {
  PROJECT_MANAGER
  CONTRIBUTOR
}

enum ContributionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum NotificationType {
  CONTRIBUTION_REQUEST_SUBMITTED
  CONTRIBUTION_REQUEST_APPROVED
  CONTRIBUTION_REQUEST_REJECTED
  PROJECT_INVITED
  PROJECT_ROLE_CHANGED
  PROJECT_REMOVED
  CHAT_MENTION
}

// ─── Chat enums ──────────────────────────────────────────────────────────

enum ChatMessageKind {
  TEXT
  SYSTEM_CHANNEL_CREATED
  SYSTEM_CHANNEL_RENAMED
  SYSTEM_PINNED
}

enum ChatAttachmentKind {
  IMAGE
  VIDEO
  AUDIO
  FILE
}

enum ChatDeleteActor {
  SELF
  MODERATOR
}

// ─── Identity ────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  keycloakId  String   @unique
  email       String   @unique
  name        String
  avatarUrl   String?
  bio         String?
  isAdmin     Boolean  @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedProjects        Project[]              @relation("ProjectOwner")
  memberships          ProjectMember[]
  contributionRequests ContributionRequest[]
  resolvedRequests     ContributionRequest[]  @relation("ResolvedBy")
  notifications        Notification[]
  invitedReceived      ProjectInvite[]        @relation("InvitedUser")
  invitedSent          ProjectInvite[]        @relation("InvitedBy")
  bookmarks            Bookmark[]
  featuredAssignments  FeaturedProject[]      @relation("FeaturedBy")
  sessions             Session[]
  chatChannelsCreated  ChatChannel[]          @relation("ChatChannelCreator")
  chatChannelMembers   ChatChannelMember[]
  chatMessages         ChatMessage[]          @relation("ChatMessageAuthor")
  chatMessagesDeleted  ChatMessage[]          @relation("ChatMessageDeleter")
  chatReactions        ChatReaction[]
  chatPins             ChatPinned[]           @relation("ChatPinnedBy")
  stickerPacksCreated  StickerPack[]          @relation("StickerPackCreator")

  @@index([email])
  @@index([isAdmin])
}

// ─── Sessions (database-backed, no cookies) ───────────────────────────────

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  accessToken  String
  refreshToken String?
  idToken      String?
  
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

// ─── Tags ────────────────────────────────────────────────────────────────

model Tag {
  id        String       @id @default(uuid())
  name      String
  category  String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projects  ProjectTag[]

  @@unique([name, category])
  @@index([category])
}

// ─── Projects ────────────────────────────────────────────────────────────

model Project {
  id                  String            @id @default(uuid())
  slug                String            @unique
  title               String
  shortDescription    String
  /// Notion-style rich-text JSON document (Tiptap-compatible).
  description         Json
  /// Canonical thumbnail URL (set automatically from the first media item).
  thumbnailUrl        String?
  thumbnailType       MediaType?
  techStack           String[]          @default([])
  phase               ProjectPhase      @default(IDEA)
  visibility          ProjectVisibility @default(PRIVATE)
  collaborationRoles  String[]          @default([])
  /// { pmTool?, repository?, staging?, designs?, other?: { label, url }[] }
  internalLinks       Json?
  ownerId             String
  publishedAt         DateTime?
  archivedAt          DateTime?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  owner                User                  @relation("ProjectOwner", fields: [ownerId], references: [id])
  media                ProjectMedia[]
  tags                 ProjectTag[]
  members              ProjectMember[]
  contributionRequests ContributionRequest[]
  invites              ProjectInvite[]
  featured             FeaturedProject?
  bookmarks            Bookmark[]
  chatChannels         ChatChannel[]

  @@index([visibility, phase])
  @@index([ownerId])
  @@index([archivedAt])
  @@index([deletedAt])
}

model ProjectMedia {
  id        String    @id @default(uuid())
  projectId String
  url       String
  type      MediaType
  /// 0 = thumbnail / cover. Subsequent items are the gallery in display order.
  order     Int       @default(0)
  width     Int?
  height    Int?
  sizeBytes Int?
  createdAt DateTime  @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, order])
  @@index([projectId])
}

model ProjectTag {
  projectId String
  tagId     String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
  @@index([tagId])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  userId    String
  role      ProjectRole
  /// The collaboration role (Frontend Engineer, etc.) the user holds on this project.
  title     String?
  joinedAt  DateTime    @default(now())

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

// ─── Contributions ───────────────────────────────────────────────────────

model ContributionRequest {
  id           String                    @id @default(uuid())
  projectId    String
  userId       String
  /// The collaboration role they're applying for (e.g. "Frontend Engineer").
  role         String
  message      String
  status       ContributionRequestStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedById String?
  /// Optional moderator note shown to the applicant on approve/reject.
  resolutionNote String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  project      Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy   User?                     @relation("ResolvedBy", fields: [resolvedById], references: [id])

  @@index([projectId, status])
  @@index([userId, status])
}

model ProjectInvite {
  id            String       @id @default(uuid())
  projectId     String
  invitedUserId String
  invitedById   String
  role          ProjectRole  @default(CONTRIBUTOR)
  /// Collaboration role title to grant on acceptance.
  title         String?
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedUser   User         @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy     User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([projectId, invitedUserId, status])
  @@index([invitedUserId, status])
}

// ─── Notifications ───────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  /// Path within Atlas to navigate to (e.g. /projects/<slug>/manage/requests).
  link      String?
  /// Arbitrary payload for the frontend (project id, request id, actor id, etc.)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Featured (admin-curated dashboard hero) ─────────────────────────────

model FeaturedProject {
  projectId String   @id
  setById   String
  order     Int      @default(0)
  setAt     DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  setBy     User     @relation("FeaturedBy", fields: [setById], references: [id])

  @@index([order])
}

// ─── Configurable list of collaboration roles (admin-managed) ────────────

model CollaborationRole {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([archivedAt])
}

// ─── Bookmarks ───────────────────────────────────────────────────────────

model Bookmark {
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])
}

// ─── Webhook delivery log (so we can see if n8n is failing) ──────────────

model WebhookDelivery {
  id           String   @id @default(uuid())
  event        String
  payload      Json
  status       Int?
  responseBody String?
  attempt      Int      @default(1)
  succeeded    Boolean  @default(false)
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([event, succeeded])
  @@index([createdAt])
}

// ─── Chat ────────────────────────────────────────────────────────────────
// Realtime project chat. Channels are project-scoped; every project gets
// an auto-created `#general` (isGeneral = true). Visibility is enforced
// at the application layer via ProjectAccessService — only insiders
// (admin / project manager / contributor) may read or write.

model ChatChannel {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  slug        String
  topic       String?
  isGeneral   Boolean   @default(false)
  isArchived  Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                @relation("ChatChannelCreator", fields: [createdById], references: [id])
  messages  ChatMessage[]
  members   ChatChannelMember[]
  pinned    ChatPinned[]

  @@unique([projectId, name])
  @@index([projectId, isArchived])
}

model ChatChannelMember {
  id                String    @id @default(uuid())
  channelId         String
  userId            String
  lastReadAt        DateTime?
  lastReadMessageId String?
  muted             Boolean   @default(false)
  joinedAt          DateTime  @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId, channelId])
}

model ChatMessage {
  id                String           @id @default(uuid())
  channelId         String
  authorId          String
  kind              ChatMessageKind  @default(TEXT)
  /// Canonical GFM markdown source. Never store HTML; renderer sanitizes at read time.
  markdown          String
  replyToId         String?
  forwardedFromId   String?
  editedAt          DateTime?
  deletedAt         DateTime?
  deletedByUserId   String?
  deletedActor      ChatDeleteActor?
  /// Sender-side render metadata that doesn't belong in the core shape.
  /// Currently holds attached link previews: { linkPreviews: ChatLinkPreviewInline[] }.
  metadata          Json?
  createdAt         DateTime         @default(now())

  channel       ChatChannel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author        User             @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  deletedBy     User?            @relation("ChatMessageDeleter", fields: [deletedByUserId], references: [id])
  replyTo       ChatMessage?     @relation("ChatMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       ChatMessage[]    @relation("ChatMessageReply")
  forwardedFrom ChatMessage?     @relation("ChatMessageForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards      ChatMessage[]    @relation("ChatMessageForward")
  attachments   ChatAttachment[]
  reactions     ChatReaction[]
  pins          ChatPinned[]

  // tsvector + GIN index + UPDATE trigger added by raw SQL migration —
  // not modeled here because Prisma can't express tsvector. Search reads
  // hit the column directly via `$queryRaw`.

  @@index([channelId, createdAt])
  @@index([authorId, createdAt])
}

model ChatAttachment {
  id          String             @id @default(uuid())
  messageId   String
  kind        ChatAttachmentKind
  url         String
  s3Key       String
  mime        String
  bytes       Int
  width       Int?
  height      Int?
  durationSec Float?
  posterUrl   String?
  createdAt   DateTime           @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  /// Unicode emoji (normalized client-side). Not a shortcode.
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChatPinned {
  id          String   @id @default(uuid())
  channelId   String
  messageId   String
  pinnedById  String
  position    Int      @default(0)
  pinnedAt    DateTime @default(now())

  channel  ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy User        @relation("ChatPinnedBy", fields: [pinnedById], references: [id])

  @@unique([channelId, messageId])
  @@index([channelId, position])
}

model ChatLinkPreview {
  id          String   @id @default(uuid())
  /// sha256 hex of the canonicalized URL.
  urlHash     String   @unique
  url         String
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  /// oEmbed iframe HTML when the source supports it (YouTube/Vimeo etc.).
  embedHtml   String?
  /// 'link' | 'video' | 'gif'.
  kind        String   @default("link")
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
}

// ─── Stickers (admin-managed global library) ─────────────────────────────

model StickerPack {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User      @relation("StickerPackCreator", fields: [createdById], references: [id])
  stickers  Sticker[]

  @@index([isArchived])
}

model Sticker {
  id        String   @id @default(uuid())
  packId    String
  name      String
  keywords  String[] @default([])
  s3Key     String
  url       String
  mime      String
  width     Int?
  height    Int?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  pack StickerPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId, position])
}
