# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST_PORT=3000
PORT=3000
APP_BASE_URL=https://atlas.labmgm.org
API_GLOBAL_PREFIX=api/v1
CORS_ORIGINS=https://atlas.labmgm.org,http://localhost:3001

# ─── Database (external host) ───────────────────────────────────────────────
DATABASE_HOST=host
DATABASE_PORT=5432
DATABASE_NAME=mgm_atlas_production
DATABASE_USER=mgm_atlas_production_user
DATABASE_PASSWORD=password
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ─── Keycloak OIDC ──────────────────────────────────────────────────────────
KEYCLOAK_BASE_URL=https://iam.labmgm.org
KEYCLOAK_REALM=mgm
KEYCLOAK_CLIENT_ID=mgm-atlas
KEYCLOAK_ISSUER=https://iam.labmgm.org/realms/mgm
KEYCLOAK_JWKS_URI=https://iam.labmgm.org/realms/mgm/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=account
# Verify Keycloak tokens on /auth/login (default true). Emergency switch only.
AUTH_VERIFY_TOKENS=true

# ─── Observability (Phase 7; all optional — empty = off, app ships dark) ────
# Bearer token for GET /api/v1/metrics (Prometheus scrape). Empty → 404.
METRICS_TOKEN=
# Sentry/GlitchTip DSN for error tracking. Empty → no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# ─── Bootstrap admin & admin notification list ──────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@labmgm.org
ADMIN_NOTIFICATION_EMAILS=admin@labmgm.org

# ─── AWS S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=mgm-atlas-media
AWS_S3_PUBLIC_BASE_URL=https://cdn.labmgm.org
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_UPLOAD_PRESIGN_TTL=300

# ─── Upload limits ──────────────────────────────────────────────────────────
MEDIA_MAX_IMAGE_BYTES=10485760
MEDIA_MAX_VIDEO_BYTES=104857600
MEDIA_MAX_GALLERY_ITEMS=10
MEDIA_ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/gif
MEDIA_ALLOWED_VIDEO_MIME=video/mp4,video/webm

# ─── n8n webhook ────────────────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.labmgm.org
N8N_WEBHOOK_PATH=/webhook/atlas
N8N_WEBHOOK_SECRET=replace_me_with_random_hex

# ─── Mailtrap (system-internal SMTP, used for fallback only) ────────────────
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=replace_me
MAIL_PASSWORD=replace_me
MAIL_FROM_ADDRESS=no-reply@labmgm.org
MAIL_FROM_NAME=MGM Atlas

# ─── JWT (signing keys for any internal short-lived tokens, e.g. invites) ──
INTERNAL_JWT_SECRET=replace_me_with_64_hex_characters

# ─── Throttler ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── Chat realtime ──────────────────────────────────────────────────────────
# Leave REDIS_URL empty to keep chat in REST/polling mode (sockets disabled).
# Set to redis://host:port/db to enable presence, typing, and live message
# delivery. The container boots either way.
REDIS_URL=
CHAT_SOCKET_PATH=/socket.io
CHAT_LINK_PREVIEW_CACHE_TTL=86400
CHAT_MAX_ATTACHMENTS_PER_MESSAGE=10
CHAT_MAX_ATTACHMENT_BYTES=52428800
CHAT_EDIT_WINDOW_HOURS=24

# Tenor (Google) is the primary GIF provider. Giphy is an optional fallback.
# Without either, the GIF tab in the picker is hidden.
TENOR_API_KEY=
GIPHY_API_KEY=

# ─── PMO (project management office) ────────────────────────────────────────
# Global kill switch. Stays "false" until Phase 1 ships so the foundation
# tables can be migrated dark. Flip to "true" only after the UI is ready.
PMO_ENABLED=false
PMO_MAX_TASKS_PER_LIST=2000
PMO_MAX_LISTS_PER_PROJECT=50
PMO_MAX_NOTES_PER_PROJECT=500
PMO_MAX_WHITEBOARDS_PER_PROJECT=100
PMO_MAX_TABS_PER_LIST=20
PMO_FILE_MAX_BYTES=52428800
# Comma-separated MIME allowlist for the Files tab. Use * for any.
PMO_FILE_ALLOWED_MIME=*

# ─── Yjs realtime collab (notes + whiteboards) ──────────────────────────────
# Leave YJS_PUBLIC_WS_URL empty to keep notes/whiteboards in single-edit
# mode (used until Phase 8 lands). When set, the frontend connects here
# for live CRDT sync. The y-websocket sidecar in docker-compose calls
# back into the backend using YJS_INTERNAL_AUTH_SECRET to authorize joins
# and persist snapshots.
YJS_PUBLIC_WS_URL=
YJS_INTERNAL_AUTH_SECRET=
YJS_SNAPSHOT_DEBOUNCE_MS=30000
# Host port for the y-websocket sidecar container. Only matters when
# the sidecar is reverse-proxied at a public host (e.g. yjs.atlas.labmgm.org).
YJS_HOST_PORT=1234

# ─── Voice chat (Phase 0) ─────────────────────────────────────────────────
# Global kill switch. Off by default. When false, every /voice/* route
# 404s and no LiveKit connection is attempted (backend boots unchanged).
VOICE_ENABLED=false
# LiveKit signaling base URL, e.g. wss://<your-domain>/livekit —
# served by your reverse proxy in front of the LiveKit container.
# Leave empty to make the feature report "unavailable" rather than crash.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# HMAC secret LiveKit uses to sign webhook deliveries.
LIVEKIT_WEBHOOK_KEY=
# TTL for LiveKit access tokens minted by the backend (default 4h).
VOICE_JWT_TTL_SECONDS=14400
# Default channel user-limit (0 = unlimited).
VOICE_DEFAULT_USER_LIMIT=0
# Phase 7 recording retention (days). 0 = keep forever.
VOICE_RECORDING_RETENTION_DAYS=30
# Host port for the LiveKit container (signaling). Internal-only by default;
# your reverse proxy forwards wss://<your-domain>/livekit to this.
LIVEKIT_HOST_PORT=7880

# ─── Web Push (browser notifications) ────────────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys
# When any of these is empty, backend boots fine but push dispatch is a
# no-op (in-app notifications still persist and emit via socket). Frontend
# detects an empty public key and hides the "Enable browser notifications"
# UI, falling back to in-app delivery only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# RFC 8292 contact identity — either `mailto:you@example.org` or your origin.
VAPID_SUBJECT=mailto:dev@labmgm.org
